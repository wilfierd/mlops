project     = "llm-chat"
environment = "dev"
region      = "us-west-2"

worker_az = "us-west-2a"
extra_az  = "us-west-2b"

eks_version = "1.30"

node_instance_types = ["m7g.xlarge"]
node_capacity_type  = "ON_DEMAND"
node_min_size       = 1
node_desired_size   = 2
node_max_size       = 4

image_tag        = "0.1.0"
model_id         = "Qwen/Qwen3-0.6B"
ray_replica_max  = 3
ray_replica_cpus = 3

monthly_budget_usd  = 100
budget_alert_emails = []  # ["you@example.com"] to enable email alerts

enable_observability   = true
grafana_admin_password = ""  # empty = auto-generate, fetch via `terraform output -raw grafana_admin_password`

tags = {
  Owner = "your-name"
}
