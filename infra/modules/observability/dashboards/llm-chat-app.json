{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["llm", "chat", "app"],
  "time": {"from": "now-30m", "to": "now"},
  "refresh": "5s",
  "title": "LLM Chat — Application",
  "uid": "llm-chat-app",
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "Application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(ray_serve_num_router_requests_total{application!=\"\"}, application)",
        "refresh": 1,
        "sort": 1,
        "current": {"text": "llm-chat", "value": "llm-chat"},
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "RPS — /qa",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_serve_num_router_requests_total{application=~\"$app\", route=\"/qa\"}[30m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2}}
    },
    {
      "id": 2,
      "title": "p50 /qa",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}) by (le)) / 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 2}}
    },
    {
      "id": 3,
      "title": "p95 /qa",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}) by (le)) / 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "p99 /qa",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}) by (le)) / 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 2}}
    },
    {
      "id": 5,
      "title": "Error rate %",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 * (sum(rate(ray_serve_num_http_error_requests_total{application=~\"$app\", route=\"/qa\"}[30m])) or vector(0)) / clamp_min((sum(rate(ray_serve_num_router_requests_total{application=~\"$app\", route=\"/qa\"}[30m])) or vector(0)), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "vLLM generation tokens/s",
      "type": "stat",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(vllm:generation_tokens_total[30m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}},
      "description": "Actual generation token throughput from the vLLM server."
    },
    {
      "id": 7,
      "title": "Request rate per route",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_serve_num_router_requests_total{application=~\"$app\"}[30m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 8,
      "title": "Latency p50 / p95 / p99 — /qa",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 9,
      "title": "Requests per replica (last 5m)",
      "type": "barchart",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(ray_serve_deployment_request_counter_total{application=~\"$app\"}[30m])) by (replica)",
          "legendFormat": "{{replica}}",
          "refId": "A"
        }
      ],
      "description": "Hot replica? Even distribution? Check load balance across the 2 actors per pod."
    },
    {
      "id": 10,
      "title": "HTTP status code split",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_serve_num_router_requests_total{application=~\"$app\"}[30m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 11,
      "title": "Deployment processing latency p95 (model.generate only)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(ray_serve_deployment_processing_latency_ms_bucket{application=~\"$app\"}) by (le, deployment))",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "description": "HTTP latency includes proxy + serialization. This isolates pure inference latency inside the actor."
    },
    {
      "id": 12,
      "title": "Ray Metrics Scrape Up",
      "type": "stat",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max(up{namespace=\"llm-chat\", endpoint=\"metrics\"})",
          "legendFormat": "scrape up",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "description": "1 means Prometheus can scrape Ray head metrics. This is more reliable than health route traffic, which may not pass through Ray Serve."
    }
  ]
}
