{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["llm", "chat", "app"],
  "time": {"from": "now-30m", "to": "now"},
  "refresh": "5s",
  "title": "LLM Chat — SLO Overview",
  "uid": "llm-chat-app",
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "Application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(ray_serve_num_router_requests_total{application!=\"\"}, application)",
        "refresh": 1,
        "sort": 1,
        "current": {"text": "llm-chat", "value": "llm-chat"},
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "RPS — /qa",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_serve_num_router_requests_total{application=~\"$app\", route=\"/qa\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2}}
    },
    {
      "id": 2,
      "title": "p50 /qa",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) by (le)) / 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 2}}
    },
    {
      "id": 3,
      "title": "p95 /qa",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) by (le)) / 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "TTFT p95",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_rag_qa_ttft_ms_bucket[$__rate_interval])) by (le))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {"defaults": {"unit": "ms", "decimals": 0}},
      "description": "Time to first token observed by RagApi. This is the perceived-latency signal for streaming UX."
    },
    {
      "id": 5,
      "title": "Error rate %",
      "type": "stat",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
	          "expr": "100 * (sum(rate(ray_serve_num_http_error_requests_total{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) or vector(0)) / clamp_min((sum(rate(ray_serve_num_router_requests_total{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) or vector(0)), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "vLLM generation tokens/s",
      "type": "stat",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(vllm:generation_tokens_total[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1}},
      "description": "Actual generation token throughput from the vLLM server."
    },
    {
      "id": 7,
      "title": "Request rate per route",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_serve_num_router_requests_total{application=~\"$app\"}[$__rate_interval])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 8,
      "title": "Latency p50 / p95 / p99 — /qa",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ray_serve_http_request_latency_ms_bucket{application=~\"$app\", route=\"/qa\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 9,
      "title": "Request rate per deployment",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_serve_deployment_request_counter_total{application=~\"$app\"}[5m])) by (deployment)",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2}
        }
      },
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "description": "Rate per deployment (RagApi / Embedder). Flat line = stable. Spike = burst. Drop = replica restart."
    },
    {
      "id": 10,
      "title": "QA Request Status (ok / fallback / error)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ray_rag_qa_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 2}
        }
      },
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "description": "ok = answered, fallback = backpressure/timeout/no_hits, error = 5xx bugs."
    },
    {
      "id": 11,
      "title": "Deployment processing latency p95",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_serve_deployment_processing_latency_ms_bucket{application=~\"$app\"}[$__rate_interval])) by (le, deployment))",
          "legendFormat": "{{deployment}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}},
      "description": "Ray Serve actor processing latency by deployment. For RagApi this includes retrieval + LLM call; use RAG Pipeline for step breakdown."
    },
    {
      "id": 12,
      "title": "QA Fallback by Reason",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(ray_rag_qa_fallback_total[$__range])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "custom": {"lineWidth": 2}
        }
      },
      "options": {"legend": {"displayMode": "list"}, "tooltip": {"mode": "multi"}},
      "description": "Total fallbacks in the selected time range. Empty = no fallbacks (healthy). backpressure = 429; llm_timeout = decode too slow; no_hits = retrieval miss."
    }
  ]
}
