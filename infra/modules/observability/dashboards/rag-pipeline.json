{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "RAG pipeline observability: QA latency, fallbacks, ingest throughput, vLLM/Qdrant health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "QA Endpoint",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_rag_qa_latency_ms_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_rag_qa_latency_ms_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ray_rag_qa_latency_ms_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "QA End-to-End Latency (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (pod) (rate(vllm:generation_tokens_total[$__rate_interval]))",
          "legendFormat": "{{pod}} gen tokens/s",
          "refId": "A"
        }
      ],
      "title": "LLM Generated Tokens/s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_rag_qa_step_latency_ms_bucket{step!=\"llm\"}[$__rate_interval])) by (le, step))",
          "legendFormat": "{{step}}",
          "refId": "A"
        }
      ],
      "title": "Retrieval Step p95 (embed / qdrant / mmr)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(increase(ray_rag_qa_fallback_total[$__range])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "noValue": "0"
        }
      },
      "title": "QA Fallback Count by Reason",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 17 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "ray_rag_qa_inflight",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ],
      "title": "QA In-Flight Requests",
      "type": "stat"
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 101,
      "title": "Ingest Pipeline (expand when uploading docs)",
      "type": "row",
      "panels": []
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(ray_rag_ingest_docs_total[$__rate_interval])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Document Upload Rate by Result",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(ray_rag_ingest_chunks_total[$__rate_interval]))",
          "legendFormat": "chunks/s",
          "refId": "A"
        }
      ],
      "title": "Ingest Chunk Throughput (chunks/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "vLLM",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 8,
      "targets": [
        {
          "expr": "sum by (pod) (vllm:num_requests_waiting)",
          "legendFormat": "{{pod}} waiting",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (vllm:num_requests_running)",
          "legendFormat": "{{pod}} running",
          "refId": "B"
        }
      ],
      "title": "vLLM Queue Depth (waiting / running)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 9,
      "targets": [
        {
          "expr": "sum by (pod) (rate(vllm:generation_tokens_total[$__rate_interval]))",
          "legendFormat": "{{pod}} gen tokens/s",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (rate(vllm:prompt_tokens_total[$__rate_interval]))",
          "legendFormat": "{{pod}} prompt tokens/s",
          "refId": "B"
        }
      ],
      "title": "vLLM Token Throughput",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "title": "Qdrant",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 10,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rest_responses_duration_seconds_bucket{exported_endpoint=\"/collections/{name}/points/query\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95 search ms",
          "refId": "A"
        }
      ],
      "title": "Qdrant Search Latency p95 (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "noValue": "0" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 40 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "orientation": "auto"
      },
      "targets": [
        {
          "expr": "collections_vector_total",
          "legendFormat": "vectors",
          "refId": "A"
        }
      ],
      "title": "Indexed Vectors",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "noValue": "0" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 40 },
      "id": 23,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(rate(grpc_responses_total[$__rate_interval]))",
          "legendFormat": "gRPC/s",
          "refId": "A"
        }
      ],
      "title": "Qdrant gRPC req/s",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 104,
      "title": "vLLM Runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "id": 12,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "vLLM TTFT (ms)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "id": 13,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:request_generation_tokens_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:request_generation_tokens_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "title": "vLLM Output Tokens per Request",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "id": 14,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:request_prefill_time_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "prefill p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:request_decode_time_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "decode p95",
          "refId": "B"
        }
      ],
      "title": "vLLM Prefill vs Decode Time p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 57 },
      "id": 15,
      "targets": [
        {
          "expr": "max by (pod) (vllm:kv_cache_usage_perc * 100)",
          "legendFormat": "{{pod}} kv cache %",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (increase(vllm:num_preemptions_total[$__rate_interval]))",
          "legendFormat": "{{pod}} preemptions",
          "refId": "B"
        }
      ],
      "title": "vLLM KV Cache & Preemptions",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 65 },
      "id": 105,
      "title": "Kubernetes Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 66 },
      "id": 16,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"llm-chat\", container!=\"\", image!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage (cores)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "decgbytes",
          "decimals": 2
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 66 },
      "id": 17,
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"llm-chat\", container!=\"\", image!=\"\"}) by (pod) / 1024 / 1024 / 1024",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Memory Working Set (GiB)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 74 },
      "id": 18,
      "targets": [
        {
          "expr": "100 * sum(rate(container_cpu_cfs_throttled_periods_total{namespace=\"llm-chat\", container!=\"\", image!=\"\"}[5m])) by (pod) / clamp_min(sum(rate(container_cpu_cfs_periods_total{namespace=\"llm-chat\", container!=\"\", image!=\"\"}[5m])) by (pod), 1)",
          "legendFormat": "{{pod}} throttled",
          "refId": "A"
        }
      ],
      "title": "CPU Throttling (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 74 },
      "id": 19,
      "targets": [
        {
          "expr": "100 * kubelet_volume_stats_used_bytes{namespace=\"llm-chat\", persistentvolumeclaim=~\"qdrant-data-pvc|llm-cache-pvc\"} / kubelet_volume_stats_capacity_bytes{namespace=\"llm-chat\", persistentvolumeclaim=~\"qdrant-data-pvc|llm-cache-pvc\"}",
          "legendFormat": "{{persistentvolumeclaim}}",
          "refId": "A"
        }
      ],
      "title": "PVC Disk Usage (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 82 },
      "id": 20,
      "targets": [
        {
          "expr": "sum(rate(container_fs_reads_bytes_total{namespace=\"llm-chat\", container!=\"\", image!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}} read",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_fs_writes_bytes_total{namespace=\"llm-chat\", container!=\"\", image!=\"\"}[5m])) by (pod)",
          "legendFormat": "{{pod}} write",
          "refId": "B"
        }
      ],
      "title": "Container Disk IO (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 82 },
      "id": 21,
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"llm-chat\"}[5m])) by (pod)",
          "legendFormat": "{{pod}} rx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"llm-chat\"}[5m])) by (pod)",
          "legendFormat": "{{pod}} tx",
          "refId": "B"
        }
      ],
      "title": "Pod Network IO (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 90 },
      "id": 22,
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=\"llm-chat\"}[30m])) by (pod)",
          "legendFormat": "{{pod}} restarts",
          "refId": "A"
        }
      ],
      "title": "Pod Restarts (last 30m)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 96 },
      "id": 106,
      "title": "RAG Retrieval Quality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "decimals": 2
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 97 },
      "id": 24,
      "targets": [
        {
          "expr": "histogram_quantile(0.05, sum(rate(ray_rag_retrieval_top_score_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p05",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_rag_retrieval_top_score_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "title": "Retrieval Top Score",
      "type": "timeseries",
      "description": "Low p05/p50 means retrieval quality is weak. If this drops while Qdrant latency is normal, tune chunking, score_threshold, or embeddings."
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "decimals": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 97 },
      "id": 25,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_rag_retrieval_hits_raw_bucket[$__rate_interval])) by (le))",
          "legendFormat": "raw p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_rag_retrieval_hits_selected_bucket[$__rate_interval])) by (le))",
          "legendFormat": "selected p50",
          "refId": "B"
        }
      ],
      "title": "Retrieval Hits",
      "type": "timeseries",
      "description": "raw = hits above score_threshold before MMR; selected = chunks passed to the LLM. raw=0 drives no_hits fallbacks."
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "decimals": 0
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 97 },
      "id": 26,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ray_rag_qa_completion_tokens_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ray_rag_qa_completion_tokens_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
