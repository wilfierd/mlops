{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["ray", "system"],
  "time": {"from": "now-30m", "to": "now"},
  "refresh": "10s",
  "title": "Ray Cluster — Operations",
  "uid": "ray-cluster-ops",
  "templating": {
    "list": [
      {
        "name": "app",
        "label": "Application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(ray_serve_num_router_requests_total{application!=\"\"}, application)",
        "refresh": 1,
        "sort": 1,
        "current": {"text": "llm-chat-dev", "value": "llm-chat-dev"},
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Running replicas",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(ray_serve_deployment_replica_healthy{application=\"$app\"})",
          "legendFormat": "running",
          "refId": "A"
        }
      ],
      "options": {"colorMode": "value", "graphMode": "area"}
    },
    {
      "id": 2,
      "title": "Target replicas (autoscaler)",
      "type": "stat",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max(ray_serve_autoscaling_target_replicas{application=\"$app\"})",
          "legendFormat": "target",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Ray nodes",
      "type": "stat",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "count(ray_node_cpu_utilization)",
          "legendFormat": "nodes",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Ray actors (alive)",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(ray_actors{State=\"ALIVE\"})",
          "legendFormat": "alive",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Replica count over time",
      "type": "timeseries",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(ray_serve_deployment_replica_healthy{application=\"$app\"}) by (deployment)",
          "legendFormat": "{{deployment}} running",
          "refId": "A"
        },
        {
          "expr": "max(ray_serve_autoscaling_target_replicas{application=\"$app\"}) by (deployment)",
          "legendFormat": "{{deployment}} target",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}},
      "description": "Running vs target. Gap during scale-up = pods being spawned."
    },
    {
      "id": 6,
      "title": "Ongoing requests per replica",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "ray_serve_num_ongoing_requests_at_replicas{application=\"$app\"}",
          "legendFormat": "{{deployment}} {{handle}}",
          "refId": "A"
        }
      ],
      "description": "When this hits max_ongoing_requests=1 sustained, autoscaler scales out."
    },
    {
      "id": 7,
      "title": "Pending (queued) per replica",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "ray_serve_deployment_queued_queries{application=\"$app\"}",
          "legendFormat": "{{deployment}} {{handle}}",
          "refId": "A"
        }
      ],
      "description": "Pending > 0 means proxy queued requests at this replica."
    },
    {
      "id": 8,
      "title": "Ray node CPU utilization (%)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "ray_node_cpu_utilization",
          "legendFormat": "{{NodeAddress}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    },
    {
      "id": 9,
      "title": "Ray node memory used (GiB)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "ray_node_mem_used / 1024 / 1024 / 1024",
          "legendFormat": "{{NodeAddress}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "decgbytes", "decimals": 2}}
    },
    {
      "id": 10,
      "title": "Replica spawns (events)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(ray_serve_replica_startup_latency_ms_count{application=\"$app\"}[5m])) by (deployment)",
          "legendFormat": "{{deployment}} startups",
          "refId": "A"
        }
      ],
      "description": "Spikes = replica spawned. Frequent spikes during steady traffic = crashloop."
    },
    {
      "id": 11,
      "title": "Total router requests handled",
      "type": "stat",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(ray_serve_num_router_requests_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
